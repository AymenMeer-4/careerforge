# Neon Postgres connection string
DATABASE_URL=

# Anthropic API key — powers all Claude integrations
ANTHROPIC_API_KEY=

# Resend — transactional email (interview/offer notifications)
RESEND_API_KEY=
# Verified sender; falls back to onboarding@resend.dev if unset
RESEND_FROM=

# iron-session cookie encryption secret (min 32 chars)
SESSION_PASSWORD=

# Dev server origin used by scripts/seed.mjs for roadmap generation (optional)
SEED_BASE_URL=http://localhost:3000
